# Placeholder names only — never commit real values.
# Copy to .env or use `dotnet user-secrets` for local development.

ASPNETCORE_ENVIRONMENT=Development

# Connector API
CONNECTOR_HTTP_PORT=5203
FieldFlow__BaseUrl=http://localhost:5210
FieldFlow__ApiKey=replace-me
FieldFlow__WebhookHmacSecret=replace-me
FieldFlow__ProviderInstanceId=fieldflow-local-1
FieldFlow__Resilience__AttemptTimeoutMilliseconds=3000
FieldFlow__Resilience__MaxRetryAttempts=3
FieldFlow__Resilience__CircuitMinimumThroughput=5
FieldFlow__Resilience__CircuitBreakDurationSeconds=15
ConnectorHealth__OfflineNoSuccessSeconds=300

# Persistence (Prompt 02+)
CONNECTION_STRING=Data Source=connector.db

# FieldFlow mock (ASP.NET Core configuration binding)
MOCK_HTTP_PORT=5210
FieldFlowMock__ApiKey=replace-me
FieldFlowMock__WebhookHmacSecret=replace-me
FieldFlowMock__ProviderInstanceId=fieldflow-local-1
