{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ConnectorPersistence": {
    "ConnectionString": "Data Source=connector.dev.db",
    "ApplyMigrationsOnStartup": true
  },
  "FieldFlow": {
    "BaseUrl": "http://localhost:5210",
    "ApiKey": "replace-me",
    "WebhookHmacSecret": "replace-me",
    "ProviderInstanceId": "fieldflow-local-1",
    "TimeoutMilliseconds": 60000,
    "WebhookTimestampSkewSeconds": 300,
    "MaxWebhookBodyBytes": 65536,
    "Resilience": {
      "AttemptTimeoutMilliseconds": 3000,
      "MaxRetryAttempts": 3,
      "BaseDelayMilliseconds": 200,
      "MaxDelayMilliseconds": 5000,
      "MaxRetryAfterMilliseconds": 30000,
      "DisableRetryDelays": false,
      "CircuitFailureRatio": 0.5,
      "CircuitMinimumThroughput": 5,
      "CircuitSamplingDurationSeconds": 30,
      "CircuitBreakDurationSeconds": 15,
      "ConcurrencyLimit": 64,
      "ConcurrencyQueueLimit": 128
    }
  },
  "ConnectorHealth": {
    "DegradedInboxBacklogThreshold": 50,
    "DegradedOutboxBacklogThreshold": 50,
    "DegradedRateLimitThreshold": 3,
    "OfflineNoSuccessSeconds": 300,
    "RateLimitTrendWindowSeconds": 900
  },
  "InboundSync": {
    "PollingEnabled": false,
    "PollingIntervalSeconds": 60,
    "MaxProcessBatch": 100
  },
  "OutboundDispatch": {
    "WorkerEnabled": true,
    "WorkerIntervalSeconds": 2,
    "MaxProcessBatch": 50,
    "MaxAttempts": 8
  }
}
